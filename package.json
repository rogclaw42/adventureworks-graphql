{
  "name": "adventureworks-graphql",
  "version": "1.0.0",
  "description": "Production-quality GraphQL API on AdventureWorks SQLite database",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build-db": "node build-db.js",
    "test": "node src/test-queries.js",
    "generate-schema": "node src/utils/generateDocs.js",
    "start:dev": "LOG_QUERIES=true node src/server.js",
    "start:prod": "NODE_ENV=production LOG_QUERIES=false node src/server.js"
  },
  "keywords": [
    "graphql",
    "adventureworks",
    "sqlite",
    "apollo",
    "nodejs"
  ],
  "author": "rogclaw42",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@graphql-tools/schema": "^10.0.31",
    "better-sqlite3": "^12.8.0",
    "dataloader": "^2.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "graphql": "^16.13.2",
    "graphql-depth-limit": "^1.1.0",
    "graphql-http": "^1.22.4",
    "graphql-query-complexity": "^1.1.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.8",
    "graphql-yoga": "^5.18.1",
    "ws": "^8.20.0"
  }
}
